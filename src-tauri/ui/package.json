{
  "name": "textbrush-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Textbrush Tauri UI",
  "scripts": {
    "build": "esbuild main.ts --bundle --outfile=bundle.js --format=esm --target=es2022",
    "build:modules": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint *.ts",
    "check": "npm run typecheck && npm run lint",
    "test": "npm run build:modules && node --test *.test.js"
  },
  "dependencies": {
    "exifreader": "^4.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/api": "^2.10.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
